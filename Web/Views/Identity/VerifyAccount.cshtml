@model Application.Dtos.Identity.VerifyAccountRequest

@{
    ViewData["Title"] = "Account Verification";
}

<div class="row justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="col-md-5 col-lg-4">
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-body p-4 p-md-5 text-center">

                <div class="mb-4">
                    <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" fill="currentColor" class="bi bi-envelope-check text-primary" viewBox="0 0 16 16">
                        <path d="M2 2a2 2 0 0 0-2 2v8.01A2 2 0 0 0 2 14h5.5a.5.5 0 0 0 0-1H2a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1h12a1 1 0 0 1 1 1v3.5a.5.5 0 0 0 1 0V4a2 2 0 0 0-2-2H2zm3.708 6.208L1 11.105V5.383l4.708 2.825zM1 4.217V4a.5.5 0 0 1 .5-.5h13a.5.5 0 0 1 .5.5v.217l-7 4.2-7-4.2z" />
                        <path d="M16 12.5a3.5 3.5 0 1 1-7 0 3.5 3.5 0 0 1 7 0zm-1.993-1.679a.5.5 0 0 0-.686.172l-1.17 1.95-.547-.547a.5.5 0 0 0-.708.708l.774.773a.75.75 0 0 0 1.174-.144l1.335-2.226a.5.5 0 0 0-.172-.686z" />
                    </svg>
                </div>

                <h3 class="fw-bold mb-2">Account Verification</h3>
                <p class="text-muted small mb-4">
                    We have sent a 6-digit OTP code to the email <br />
                    <strong>@Model.Email</strong>
                </p>

                <form asp-controller="Identity" asp-action="VerifyAccount" method="post">

                    <input type="hidden" asp-for="Email" />

                    <div class="mb-4 text-start">
                        <label asp-for="OtpCode" class="form-label fw-medium">Enter OTP Code</label>
                        <input asp-for="OtpCode" type="text" class="form-control form-control-lg bg-light text-center fw-bold" placeholder="• • • • • •" maxlength="6" required autocomplete="off" />
                        <span asp-validation-for="OtpCode" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 py-2 mb-3 rounded-3 fw-medium">
                        Verify Now
                    </button>
                </form>

                <form asp-controller="Identity" asp-action="ResendVerifyOtp" method="post" class="mb-4">
                    <input type="hidden" name="email" value="@Model.Email" />
                    <p class="text-muted small mb-0">
                        Didn't receive the code?
                        <button type="submit" class="btn btn-link p-0 text-decoration-none fw-medium ms-1">
                            Resend OTP
                        </button>
                    </p>
                </form>

                <div class="text-center small">
                    <a href="/Identity/Login" class="text-decoration-none text-muted">
                        <i class="bi bi-arrow-left"></i> Back to Login
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>