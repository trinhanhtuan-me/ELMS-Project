@model Application.Dtos.Identity.RegisterRequest
@using Domain.Enums

@{
    ViewData["Title"] = "Sign Up";
}


<div class="container mt-5">
    <div class="row bg-white shadow rounded p-4">

        <div class="col-6 pe-5">
            <h2 class="mb-4 font-weight-bold">Create an Account</h2>

            <form asp-controller="Identity" asp-action="Register" method="post">

                <div class="form-group mb-3">
                    <label>Username:</label>
                    <input asp-for="Username" class="form-control" />
                    <span asp-validation-for="Username" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label>Email:</label>
                    <input asp-for="Email" type="email" class="form-control" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label>Password:</label>
                    <input asp-for="Password" type="password" class="form-control" />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label>Confirm Password:</label>
                    <input asp-for="ConfirmPassword" type="password" class="form-control" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label class="d-block">Gender:</label>
                    <div class="form-check form-check-inline">
                        <input class="form-check-input" type="radio" asp-for="Gender" value="@Gender.Male">
                        <label class="form-check-label">Male</label>
                    </div>
                    <div class="form-check form-check-inline">
                        <input class="form-check-input" type="radio" asp-for="Gender" value="@Gender.Female">
                        <label class="form-check-label">Female</label>
                    </div>
                    <div class="form-check form-check-inline">
                        <input class="form-check-input" type="radio" asp-for="Gender" value="@Gender.Other">
                        <label class="form-check-label">Other</label>
                    </div>
                    <br />
                    <span asp-validation-for="Gender" class="text-danger"></span>
                </div>

                <div class="form-group mb-4">
                    <label class="d-block">Role:</label>
                    <div class="form-check form-check-inline">
                        <input class="form-check-input" type="radio" asp-for="IsStudent" value="true">
                        <label class="form-check-label">Student</label>
                    </div>
                    <div class="form-check form-check-inline">
                        <input class="form-check-input" type="radio" asp-for="IsStudent" value="false">
                        <label class="form-check-label">Parent</label>
                    </div>
                    <br />
                    <span asp-validation-for="IsStudent" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-primary w-100 mb-3" style="border-radius: 8px;">
                    Sign Up
                </button>

                <p class="text-muted">
                    Already have an account? <a href="/Identity/Login" class="text-primary text-decoration-none">Log in</a>
                </p>
            </form>
        </div>

        <div class="col-6 d-flex align-items-center justify-content-center bg-light rounded">
            <img src="/images/register-illustration.png" alt="Registration Illustration" class="img-fluid" style="max-height: 500px;" />
        </div>

    </div>
</div>