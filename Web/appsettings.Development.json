{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "ConnectionStrings": {
    "DefaultConnection": "",
    "Redis": ""
  },

  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "System": "Warning",
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore.Database.Command": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "MSSqlServer",
        "Args": {
          "connectionString": "",
          "sinkOptionsSection": {
            "tableName": "p_logerror",
            "autoCreateSqlTable": true
          },
          "restrictedToMinimumLevel": "Error"
        }
      },
      {
        "Name": "Console"
      }
    ]
  },

  "Mail": {
    "Host": "",
    "Port": 587,
    "SenderEmail": "",
    "Username": "",
    "Password": ""
  }
}
